# MongoDB connection string
# Local: mongodb://localhost:27017/galaxyex
# Atlas:  mongodb+srv://user:password@cluster.mongodb.net/galaxyex
MONGODB_URI=mongodb://localhost:27017/galaxyex

# JWT secret — use a long random string in production
JWT_SECRET=change-me-in-production

# Server port (default 8080)
PORT=8080

# Comma-separated list of allowed CORS origins (leave empty to allow all)
# Example: CORS_ORIGINS=https://your-frontend.vercel.app
CORS_ORIGINS=
